APP_ENV=dev
BASE_URL=http://localhost:8000

# Required for LLM-based routing
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Required in prod to protect the API
API_KEY=

# Optional — Gmail & Calendar tools fall back to mocks when not set
ARCADE_API_KEY=
ARCADE_USER_ID=

# Defaults to SQLite for local dev; set to PostgreSQL URL for prod
DATABASE_URL=sqlite:///./dev.db